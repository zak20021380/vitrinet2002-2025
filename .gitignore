```gitignore
# Compiled and build artifacts
*.pyc
__pycache__/
*.o
*.obj
*.class
*.exe
*.dll
*.so
*.a
*.out

# Dependencies
node_modules/
venv/
.venv/
.env
.env.local
.env.*

# Build outputs
dist/
build/
target/
*.min.js
*.min.css
*.bundle.js

# Logs and temporary files
*.log
*.tmp
*.swp
*.swo

# OS generated files
.DS_Store
Thumbs.db

# Coverage reports
coverage/
htmlcov/
.coverage

# Editors
.vscode/
.idea/

# MyPy cache
.mypy_cache/
# Pytest cache
.pytest_cache/
```